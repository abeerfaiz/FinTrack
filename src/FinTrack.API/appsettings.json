{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/fintrack-.log",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "TrueLayer": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "",
    "AuthBaseUrl": "https://auth.truelayer-sandbox.com",
    "ApiBaseUrl": "https://api.truelayer-sandbox.com",
    "Scopes": "info accounts balance transactions offline_access"
  }
}